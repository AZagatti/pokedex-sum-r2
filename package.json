    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@vitest/browser-playwright": "^4.1.8",
    "lefthook": "^2.1.10",
    "playwright": "^1.60.0",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "ultracite": "^7.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-svelte": "^2.1.1"
  },
  "dependencies": {
    "@lucide/svelte": "^1.24.0",
